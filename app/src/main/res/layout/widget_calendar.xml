<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white">

    <!-- 제목 -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="다가오는 마감일"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:paddingBottom="8dp" />

    <!-- 일정이 없는 경우 -->
    <TextView
        android:id="@+id/widget_empty_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="등록된 일정이 없습니다."
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- 일정 리스트 컨테이너 -->
    <LinearLayout
        android:id="@+id/widget_list_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- 첫 번째 이벤트 카드 (간단 버전) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/widget_card_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <!-- 색상 인디케이터 -->
            <View
                android:id="@+id/widget_event_indicator"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#59ABF7"
                android:layout_marginEnd="12dp" />

            <!-- 이벤트 정보 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_event_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="청년 월세 지원"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_event_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2024.12.31"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- D-day 표시 -->
            <TextView
                android:id="@+id/widget_event_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D-30"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#59ABF7"
                android:background="@drawable/widget_dday_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

